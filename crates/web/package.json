{
  "name": "starstream-run-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Run Starstream contracts in the browser via wasmtime's Pulley interpreter.",
  "scripts": {
    "build:wasm": "cargo build -p starstream-run-web --release --target wasm32-unknown-unknown",
    "build:bindgen": "wasm-bindgen --target web --out-dir web/pkg ../../target/wasm32-unknown-unknown/release/starstream_run_web.wasm",
    "build:score": "cargo build --release --target wasm32-unknown-unknown --manifest-path ../../examples/components/score/Cargo.toml && cp ../../examples/components/score/target/wasm32-unknown-unknown/release/score.wasm web/score.wasm",
    "build": "npm run build:wasm && npm run build:bindgen && npm run build:score",
    "serve": "node serve.mjs",
    "start": "npm run build && npm run serve",
    "test:remote": "node test-remote.mjs"
  }
}
